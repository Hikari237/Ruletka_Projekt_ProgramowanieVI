<Window x:Class="Ruletka.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revolver &amp; Reaper - Wejście" Height="450" Width="450" 
        WindowStartupLocation="CenterScreen" Background="#0f0f0f">

    <Window.Resources>
        <Style TargetType="Button" x:Key="WesternBtn">
            <Setter Property="Background" Value="#2c1a1a"/>
            <Setter Property="Foreground" Value="#d3b58d"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#4a2e2e"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3d2424"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="#1c1c1c" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="20">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

                <TextBlock Text="KTO TRZYMA REWOLWER?" Foreground="#d3b58d" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="WYBIERZ ISTNIEJĄCEGO GRACZA:" Foreground="#b5a68c" Margin="0,0,0,5"/>
                <ComboBox x:Name="ExistingPlayersCombo" Height="32" Margin="0,0,0,20" SelectionChanged="ExistingPlayersCombo_SelectionChanged" FontSize="14" Background="#222" Foreground="Black"/>

                <TextBlock Text="LUB WPISZ NOWE IMIĘ:" Foreground="#b5a68c" Margin="0,0,0,5"/>
                <TextBox x:Name="PlayerNameInput" Height="32" FontSize="16" Margin="0,0,0,25" Background="#141414" Foreground="#d3b58d" BorderBrush="#4a2e2e" BorderThickness="1" Padding="5,0"/>

                <Button x:Name="StartGameButton" Content="GRAJ" Style="{StaticResource WesternBtn}" Height="45" Margin="0,0,0,15" Click="StartGameButton_Click"/>

                <Button x:Name="ShowRankingBtn" Content="RANKING" Background="Transparent" Foreground="#777" BorderThickness="0" Margin="0,0,0,10" FontSize="14" Click="ShowRankingBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#d3b58d"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="ExitAppBtn" Content="WYJDŹ Z GRY" Background="Transparent" Foreground="#a13d3d" BorderThickness="0" FontSize="14" Click="ExitAppBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="Red"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock x:Name="ErrorMessage" Foreground="#a13d3d" HorizontalAlignment="Center" Margin="0,15,0,0" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>