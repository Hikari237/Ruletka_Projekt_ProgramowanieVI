<Window x:Class="Ruletka.Views.RankingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ranking" Height="400" Width="434"
        WindowStartupLocation="CenterOwner" Background="#0f0f0f"
        WindowStyle="ToolWindow" ResizeMode="NoResize">

    <Grid Margin="15,15,66,15">
        <Border Background="#1c1c1c" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,-50,0">
            <Grid Margin="0,0,-57,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ULUBIEŃCY ŚMIERCI (TOP 10)" 
                           Foreground="#d3b58d" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Left" Margin="31,5,0,10"/>

                <ListView x:Name="RankingList" Grid.Row="1" Background="#141414" Foreground="#b5a68c" BorderBrush="#333" BorderThickness="1" Margin="15,0,54,0">
                    <ListView.Resources>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Background" Value="#2c1a1a"/>
                            <Setter Property="Foreground" Value="#d3b58d"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="5"/>
                        </Style>
                    </ListView.Resources>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Imię" DisplayMemberBinding="{Binding Name}" Width="120"/>
                            <GridViewColumn Header="Wygrane" DisplayMemberBinding="{Binding Wins}" Width="70"/>
                            <GridViewColumn Header="Sympatia" DisplayMemberBinding="{Binding Sympathy}" Width="80"/>
                            <GridViewColumn Header="Zgony" DisplayMemberBinding="{Binding Deaths}" Width="70"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>