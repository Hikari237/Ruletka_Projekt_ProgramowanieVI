<Window x:Class="Ruletka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revolver &amp; Reaper" Height="500" Width="814" 
        WindowStartupLocation="CenterScreen" Background="#0f0f0f">

    <Window.Resources>
        <Style TargetType="Button" x:Key="WesternBtn">
            <Setter Property="Background" Value="#2c1a1a"/>
            <Setter Property="Foreground" Value="#d3b58d"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#4a2e2e"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3d2424"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="#1c1c1c" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,10,0">
            <StackPanel VerticalAlignment="Top">
                <TextBlock x:Name="PlayerNameTxt" Text="Gracz" Foreground="#d3b58d" FontSize="24" FontWeight="Bold"/>
                <TextBlock x:Name="PlayerHpTxt" Text="HP: 100" Foreground="#a13d3d" FontSize="20" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Background="#1c1c1c" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="15" Margin="10,0,0,0">
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right">
                <TextBlock Text="Śmierć" Foreground="#555555" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right"/>
                <TextBlock x:Name="DeathHpTxt" Text="HP: 100" Foreground="#a13d3d" FontSize="20" HorizontalAlignment="Right" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#141414" BorderBrush="#2a2a2a" BorderThickness="1" CornerRadius="8" Margin="0,20,0,20" Padding="20">
            <TextBlock x:Name="StatusTxt" Text="Zapach prochu wisi w powietrzu. Twoja tura." 
                       Foreground="#b5a68c" FontSize="22" FontStyle="Italic" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
        </Border>

        <Grid Grid.Row="2" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Margin="0,0,20,0">
                <TextBlock Text="Torba:" Foreground="#777" FontSize="14" Margin="0,0,0,5"/>
                <ComboBox x:Name="InventoryComboBox" Width="200" Height="30" Margin="0,0,0,10" Background="#222" Foreground="Black" FontSize="14"/>
                <Button x:Name="UseItemBtn" Content="Użyj Przedmiotu" Style="{StaticResource WesternBtn}" Width="200" Height="40" Click="UseItemBtn_Click"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button x:Name="SpinBtn" Content="ZAKRĘĆ BĘBNEM" Style="{StaticResource WesternBtn}" Width="150" Height="50" Margin="0,0,15,0" Click="SpinBtn_Click"/>
                <Button x:Name="ShootEnemyBtn" Content="STRZEL W ŚMIERĆ" Style="{StaticResource WesternBtn}" Width="160" Height="50" Margin="0,0,15,0" Click="ShootEnemyBtn_Click"/>
                <Button x:Name="ShootSelfBtn" Content="SKIERUJ W SIEBIE" Style="{StaticResource WesternBtn}" Width="160" Height="50" Click="ShootSelfBtn_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>